{
  "apiVersion": "veilkey.io/v1",
  "kind": "BulkApplyTemplate",
  "name": "mattermost-systemd-override",
  "format": "raw",
  "targetPath": "/etc/systemd/system/mattermost.service.d/override.conf",
  "enabled": true,
  "hooks": [
    "reload_systemd",
    "restart_mattermost"
  ],
  "bodyFile": "mattermost-systemd-override.body"
}
