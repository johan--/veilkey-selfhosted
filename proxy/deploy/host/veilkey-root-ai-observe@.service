[Unit]
Description=VeilKey root-ai observer for profile %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Environment=VEILKEY_ROOT_AI_PROFILE=%i
Environment=VEILKEY_ROOT_AI_WAIT_SECONDS=30
StandardOutput=append:/var/log/veilkey-proxy/root-ai-%i-observe.jsonl
StandardError=append:/var/log/veilkey-proxy/root-ai-%i-observe.log
ExecStart=/usr/local/bin/veilkey-root-ai-observe %i
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
