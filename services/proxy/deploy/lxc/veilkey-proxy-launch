#!/usr/bin/env bash
set -euo pipefail

profile="${1:-default}"
listen_addr="$(/usr/local/bin/veilkey-session-config proxy-listen "$profile")"
allow_hosts_enabled="$(/usr/local/bin/veilkey-session-config proxy-allow-hosts-enabled "$profile")"
mapfile -t hosts < <(/usr/local/bin/veilkey-session-config proxy-allow-hosts "$profile")
plaintext_action="$(/usr/local/bin/veilkey-session-config proxy-plaintext-action "$profile")"
mapfile -t resolve_hosts < <(/usr/local/bin/veilkey-session-config proxy-plaintext-resolve-hosts "$profile")

args=(proxy --listen "$listen_addr")
if [[ "$allow_hosts_enabled" == "true" ]]; then
  for host in "${hosts[@]}"; do
    args+=(--allow-host "$host")
  done
fi

export VEILKEY_PROXY_ACCESS_LOG_FORMAT="${VEILKEY_PROXY_ACCESS_LOG_FORMAT:-jsonl}"
export VEILKEY_PROXY_REWRITE_LOG="${VEILKEY_PROXY_REWRITE_LOG:-/var/log/veilkey-proxy/${profile}-rewrite.jsonl}"
export VEILKEY_PROXY_PLAINTEXT_ACTION="${VEILKEY_PROXY_PLAINTEXT_ACTION:-$plaintext_action}"
export VEILKEY_PROXY_ALLOW_HOSTS_ENABLED="${VEILKEY_PROXY_ALLOW_HOSTS_ENABLED:-$allow_hosts_enabled}"
if [[ "${#resolve_hosts[@]}" -gt 0 ]]; then
  export VEILKEY_PROXY_PLAINTEXT_RESOLVE_HOSTS="${VEILKEY_PROXY_PLAINTEXT_RESOLVE_HOSTS:-$(IFS=,; echo "${resolve_hosts[*]}")}"
fi
exec /usr/local/bin/veilkey-cli "${args[@]}"
