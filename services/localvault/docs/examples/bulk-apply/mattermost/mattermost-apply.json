{
  "apiVersion": "veilkey.io/v1",
  "kind": "BulkApplyWorkflow",
  "name": "mattermost-apply",
  "steps": [
    { "template": "mattermost-core-config", "order": 10 },
    { "template": "mattermost-sso-config", "order": 20 },
    { "template": "mattermost-systemd-override", "order": 30 }
  ],
  "hooks": [
    "reload_systemd",
    "restart_mattermost"
  ]
}
